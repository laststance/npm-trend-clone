# Local Development Environment
# Copy this file to .env.local and update values as needed

# Database - Local PostgreSQL via Docker Compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/npm_trend_clone?schema=public

# Cache - Local Redis via Docker Compose
UPSTASH_REDIS_REST_URL=http://localhost:6379
# Note: For local Redis, you may need a Redis REST adapter or use ioredis directly

# Auth - Better Auth
BETTER_AUTH_SECRET=your-local-dev-secret-here
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MSW (Mock Service Worker)
NEXT_PUBLIC_ENABLE_MSW_MOCK=false
APP_ENV=development
