# Local Development Environment
# Copy this file to .env.local and update values as needed

# Database - Local PostgreSQL via Docker Compose (port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/npm_trend_clone?schema=public

# Cache - Upstash-compatible Redis via Docker Compose (SRH)
# Uses Serverless Redis HTTP (https://github.com/hiett/serverless-redis-http)
# Run: docker compose up redis redis-http
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local_development_token

# Auth - Better Auth
BETTER_AUTH_SECRET=your-local-dev-secret-here

# Email - Resend (optional for local dev; emails logged to console when unset)
# RESEND_API_KEY=re_your_api_key_here
# EMAIL_FROM=npm-trends <noreply@yourdomain.com>
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MSW (Mock Service Worker)
NEXT_PUBLIC_ENABLE_MSW_MOCK=false
APP_ENV=development
