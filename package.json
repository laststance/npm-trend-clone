{
  "name": "npm-trend-clone",
  "version": "0.1.0",
  "description": "A modern clone of npmtrends.com built with Next.js 16, featuring npm package download statistics comparison and visualization",
  "author": "Ryota Murakami <ryota.murakami@laststance.io> (https://github.com/ryota-murakami)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/laststance/npm-trend-clone.git"
  },
  "homepage": "https://github.com/laststance/npm-trend-clone#readme",
  "bugs": {
    "url": "https://github.com/laststance/npm-trend-clone/issues"
  },
  "keywords": [
    "npm",
    "trends",
    "statistics",
    "nextjs",
    "typescript",
    "react"
  ],
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "build:e2e": "prisma generate && DATABASE_URL=postgresql://postgres:postgres@localhost:5433/npm_trend_clone prisma db push --accept-data-loss && NEXT_PUBLIC_ENABLE_MSW_MOCK=true APP_ENV=test next build",
    "start": "next start",
    "start:e2e": "NEXT_PUBLIC_ENABLE_MSW_MOCK=true APP_ENV=test next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "pnpm build:e2e && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6010",
    "build-storybook": "storybook build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.32.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.12",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.8",
    "@vercel/analytics": "^1.6.1",
    "better-auth": "^1.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "modern-screenshot": "^4.6.7",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.5",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.6.0",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@chromatic-com/storybook": "^4.1.3",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-vitest": "^10.1.10",
    "@storybook/nextjs": "^10.1.10",
    "@storybook/nextjs-vite": "^10.1.10",
    "@storybook/test": "^8.6.14",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.1",
    "eslint-plugin-storybook": "^10.1.10",
    "msw": "^2.12.4",
    "msw-storybook-addon": "^2.0.6",
    "playwright": "^1.57.0",
    "storybook": "^10.1.10",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
